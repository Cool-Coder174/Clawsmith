# LLM Provider API Keys (set the ones you use; unused keys can be left blank)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Path to the Cursor CLI executable (leave blank to auto-detect from PATH)
CURSOR_CLI_PATH=

# Absolute path to a custom settings.yaml (defaults to config/settings.yaml)
CLAWSMITH_CONFIG_PATH=

# Logging verbosity: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# --- OpenClaw integration ---
# HMAC-SHA256 secret for verifying inbound webhooks from OpenClaw
OPENCLAW_WEBHOOK_SECRET=
# API key for authenticating with the OpenClaw gateway
OPENCLAW_API_KEY=
# OpenClaw gateway URL (e.g. https://openclaw.example.com)
OPENCLAW_GATEWAY_URL=

# --- Config overrides (merged on top of settings.yaml) ---
# Use CLAWSMITH_<SECTION>__<KEY> with double-underscore nesting.
# Examples:
# CLAWSMITH_ROUTING__LOW_COMPLEXITY_THRESHOLD=0.5
# CLAWSMITH_MODELS__PREMIUM__MAX_TOKENS=16384
# CLAWSMITH_EXECUTION__DEFAULT_TIMEOUT=600
# CLAWSMITH_MCP_SERVER__PORT=9000
# CLAWSMITH_OPENCLAW__GATEWAY_URL=https://openclaw.example.com
# CLAWSMITH_OPENCLAW__WEBHOOK_PORT=8766
# CLAWSMITH_EXECUTION__ALLOWED_COMMANDS=["cursor","python","git"]
